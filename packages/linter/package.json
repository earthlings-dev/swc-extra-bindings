{
  "name": "@swc/linter",
  "version": "0.0.29",
  "description": "Super-fast linter based on SWC",
  "homepage": "https://swc.rs",
  "main": "./index.ts",
  "types": "./index.ts",
  "author": "Mathis Møller",
  "license": "Apache-2.0",
  "keywords": [
    "swc",
    "lint"
  ],
  "engines": {
    "bun": ">=1.3.11"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swc-project/swc.git"
  },
  "bugs": {
    "url": "https://github.com/swc-project/swc/issues"
  },
  "napi": {
    "name": "lint",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-musl",
        "i686-pc-windows-msvc",
        "aarch64-unknown-linux-gnu",
        "armv7-unknown-linux-gnueabihf",
        "aarch64-apple-darwin",
        "aarch64-linux-android",
        "aarch64-unknown-linux-musl",
        "aarch64-pc-windows-msvc",
        "armv7-linux-androideabi"
      ]
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "artifacts": "napi artifacts --dist scripts/npm",
    "prepublishOnly": "napi prepublish -p scripts/npm --tagstyle npm",
    "pack": "wasm-pack",
    "build:wasm": "bun run pack -- build ./crates/wasm --scope swc",
    "build": "napi build --cwd ../../.. --manifest-path Cargo.toml --platform -p linter_node --output-dir extra-bindings/packages/linter --js binding.js --dts binding.d.ts --release",
    "build:dev": "napi build --cwd ../../.. --manifest-path Cargo.toml --platform -p linter_node --output-dir extra-bindings/packages/linter --js binding.js --dts binding.d.ts",
    "test": "echo 'done!'",
    "version": "napi version -p scripts/npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "catalog:",
    "typescript": "catalog:",
    "@types/bun": "catalog:"
  },
  "exports": {
    ".": {
      "bun": "./index.ts",
      "default": "./index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "binding.d.ts",
    "binding.js",
    "index.ts",
    "package.json"
  ]
}
